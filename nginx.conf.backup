server {
    listen 80;
    server_name localhost;
    root /usr/share/nginx/html;

    # 1) 基础静态文件服务 (3D Viewer + data/tools)
    #    注：这里的 root 应该对应容器内挂载目录，通常是 /usr/share/nginx/html
    location / {
        add_header 'Access-Control-Allow-Origin' '*' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range' always;

        if ($request_method = 'OPTIONS') {
            add_header 'Access-Control-Allow-Origin' '*' always;
            add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
            add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range' always;
            add_header 'Content-Length' 0;
            return 204;
        }
    }
        # === 新增：转发日志请求到宿主机的 8001 端口 ===
    location /log_time {
    # 172.17.0.1 是 Docker 容器访问宿主的默认 IP
    proxy_pass http://172.17.0.1:8001;

    # 适配 CORS + 携带 X-HOHONET-TOKEN（添加 always 参数）
        add_header 'Access-Control-Allow-Origin' '*' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'Content-Type, X-HOHONET-TOKEN' always;

        # 处理 OPTIONS 预检请求
        if ($request_method = 'OPTIONS') {
            add_header 'Access-Control-Allow-Origin' '*' always;
            add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
            add_header 'Access-Control-Allow-Headers' 'Content-Type, X-HOHONET-TOKEN' always;
            add_header 'Content-Length' 0;
            return 204;
        }
}

    # === 新增：同源代理 Label Studio 图片（推荐；不需要 assets/ 目录） ===
    # 让 3D Viewer 在 http://<server>:8000 下通过 /ls/ 访问 LS(8080) 的真实图片，
    # 从而避免 WebGL 纹理加载的 CORS/跨域限制。
    # 示例：
    #   http://<server>:8000/ls/data/upload/...  ->  http://<server>:8080/data/upload/...
    location /ls/ {
        proxy_pass http://172.17.0.1:8080/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
