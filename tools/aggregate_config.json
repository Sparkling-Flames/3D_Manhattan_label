{
  "comment": "Configuration for aggregate_analysis.py - defines dataset metadata and analysis parameters",
  
  "datasets": {
    "main_manual": {
      "display_name": "Manual_Test",
      "condition": "manual",
      "subset": "test",
      "description": "Main experimental group - manual annotation only (100 samples)"
    },
    "main_semi": {
      "display_name": "SemiAuto_Test",
      "condition": "semi",
      "subset": "test",
      "description": "Main experimental group - semi-automatic with model predictions (100 samples)"
    },
    "calibration_manual": {
      "display_name": "Calibration_Manual",
      "condition": "manual",
      "subset": "calibration",
      "description": "Calibration set for expert scoring and Scheme A r_u estimation (30 samples, multi-annotated)"
    },
    "validation_manual": {
      "display_name": "Validation_Manual",
      "condition": "manual",
      "subset": "validation",
      "description": "Validation set - manual condition (60 samples)"
    },
    "validation_semi": {
      "display_name": "Validation_Semi",
      "condition": "semi",
      "subset": "validation",
      "description": "Validation set - semi-automatic condition (60 samples)"
    }
  },
  
  "metric_columns": [
    "iou_2d",
    "iou_3d",
    "depth_rmse",
    "delta_1",
    "boundary_rmse",
    "pointwise_rmse",
    "n_corners",
    "scope",
    "difficulty",
    "model_issue",
    "reliability_u",
    "reliability_u_ci_low",
    "reliability_u_ci_high",
    "active_time_s"
  ],
  
  "group_by": ["condition", "subset"],
  
  "output_formats": ["csv", "json", "markdown"],
  
  "comparison_pairs": [
    {
      "name": "Manual_vs_Semi_Test",
      "group_a": "manual:test",
      "group_b": "semi:test",
      "metrics": ["iou_2d", "iou_3d", "depth_rmse", "boundary_rmse", "active_time_s"]
    },
    {
      "name": "Manual_vs_Semi_Validation",
      "group_a": "manual:validation",
      "group_b": "semi:validation",
      "metrics": ["iou_2d", "iou_3d", "depth_rmse"]
    }
  ],
  
  "plugin_metadata": {
    "version": "1.0.0",
    "author": "HOHONET Quality Analysis Team",
    "description": "Aggregate analysis configuration for Label Studio annotation quality assessment",
    "compatible_with": "analyze_quality.py v2.x"
  }
}
